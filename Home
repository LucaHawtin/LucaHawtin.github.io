<script>
const navbar = document.getElementById("navbar");

window.addEventListener("scroll", () => {

    // Hero image is about 90vh tall
    const fadeDistance = window.innerHeight * 0.45;

    // Clamp between 0 and 1
    let progress = Math.min(window.scrollY / fadeDistance, 1);

    // Background opacity (0 → 0.9)
    navbar.style.backgroundColor = `rgba(0,0,0,${progress * 0.9})`;

    // Blur (0 → 12px)
    navbar.style.backdropFilter = `blur(${progress * 12}px)`;

    // Bottom border fades in too
    navbar.style.borderBottomColor = `rgba(255,255,255,${progress * 0.08})`;

});
</script>
